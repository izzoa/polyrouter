# dependencies
node_modules/

# build outputs & caches
dist/
.turbo/
coverage/
*.tsbuildinfo
.eslintcache

# logs & OS noise
*.log
.DS_Store

# local env files (never commit secrets)
.env
.env.*
!.env.example

# install.sh install-state sentinels (checkout mode writes these next to .env)
.polyrouter-install
