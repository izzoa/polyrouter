# dependencies
node_modules/

# build outputs & caches
dist/
.turbo/
coverage/
*.tsbuildinfo
.eslintcache

# logs & OS noise
*.log
.DS_Store

# local env files (never commit secrets)
.env
.env.*
!.env.example

# install.sh install-state sentinels (checkout mode writes these next to .env)
.polyrouter-install
.polyrouter-secrets-created

# per-user agent settings (project agent config itself is committed)
.claude/settings.local.json

# per-tool skill/command mirrors for agent tools this project doesn't use
# (committed agent config: .agents/skills is the skill source of truth, plus the
# Claude Code (.claude) and Codex (.codex) dirs — the tools actually in use here)
.agent/
.augment/
.crush/
.cursor/
.gemini/
.junie/
.opencode/

# OpenSpec planning workspace (proposals, deltas, archives) — machine-local
openspec/

# design-sync (claude.ai/design): staged converter scripts, regenerated bundle,
# machine-local verification state, and the wrapper's stage-1 compiled output.
# .design-sync/config.json, NOTES.md, conventions.md, previews/, wrapper/src ARE committed.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules
.design-sync/wrapper/solid/
