{
  "name": "polyrouter",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hostable LLM router/gateway — one OpenAI- and Anthropic-compatible endpoint with explicit-first routing, fallbacks, and spend limits",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "cross-env NODE_ENV=production node packages/control-plane/dist/main.js",
    "test": "turbo run test",
    "test:e2e": "turbo run build && npm run test:e2e -w packages/control-plane",
    "db:generate": "npm run db:generate -w packages/control-plane",
    "db:migrate": "npm run db:migrate -w packages/control-plane",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "allowScripts": {
    "esbuild@0.27.7": true,
    "unrs-resolver@1.12.2": true
  }
}
