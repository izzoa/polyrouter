{
  "name": "@polyrouter/data-plane",
  "version": "0.5.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "description": "polyrouter inference proxy (a NestJS module in the baseline; extractable to its own service per spec §3.3)",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "dev": "tsc -w -p tsconfig.build.json --preserveWatchOutput",
    "test": "jest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.28",
    "@polyrouter/shared": "*",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "undici": "^8.7.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "ioredis": "^5.11.1",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  }
}
